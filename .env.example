PORT=3000

# Supabase — get these from supabase.com → project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Resend — get from resend.com → API keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# The email address Mark will receive booking notifications at
COACH_EMAIL=mark@firststepssports.com

# The "from" address for outgoing emails (must be a verified Resend domain)
RESEND_FROM=noreply@firststepssports.com
